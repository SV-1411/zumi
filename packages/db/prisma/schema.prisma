// ZUMI — data model
// PostgreSQL · Prisma. Covers identity/RBAC, clients & projects, the AI lead
// engine, and commercial objects (quotations, invoices, meetings, files).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  // "native" for local dev; rhel target for Vercel's Linux runtime.
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Identity & RBAC
// ----------------------------------------------------------------------------

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String?
  name         String
  avatarUrl    String?
  // OAuth (Google / GitHub) — null for password accounts
  provider     String?
  providerId   String?

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  isActive   Boolean   @default(true)
  lastLoginAt DateTime?

  // a User may own a Client account (the primary contact)
  client   Client? @relation("ClientOwner")

  // authored / assigned associations
  uploadedFiles File[]         @relation("FileUploader")
  notifications Notification[]
  meetings      Meeting[]      @relation("MeetingHost")
  managedProjects Project[]    @relation("ProjectManager")
  refreshTokens RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provider, providerId])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique // ADMIN | STAFF | CLIENT
  description String?
  users       User[]
  permissions RolePermission[]

  createdAt DateTime @default(now())
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique // e.g. "lead:read", "project:write"
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ----------------------------------------------------------------------------
// Clients, projects & milestones
// ----------------------------------------------------------------------------

model Client {
  id          String  @id @default(cuid())
  company     String
  industry    String?
  website     String?
  phone       String?
  notes       String?

  // primary contact (owns the login)
  ownerUserId String? @unique
  ownerUser   User?   @relation("ClientOwner", fields: [ownerUserId], references: [id])

  projects   Project[]
  invoices   Invoice[]
  quotations Quotation[]
  meetings   Meeting[]
  files      File[]
  leads      Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProjectStatus {
  DISCOVERY
  IN_PROGRESS
  REVIEW
  LAUNCHED
  ON_HOLD
  ARCHIVED
}

model Project {
  id          String        @id @default(cuid())
  name        String
  summary     String?
  status      ProjectStatus @default(DISCOVERY)
  progress    Int           @default(0) // 0-100
  stack       String[] // tech stack tags
  startDate   DateTime?
  targetDate  DateTime?

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  managerId String?
  manager   User?   @relation("ProjectManager", fields: [managerId], references: [id])

  milestones Milestone[]
  invoices   Invoice[]
  files      File[]
  meetings   Meeting[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([status])
}

enum MilestoneStatus {
  PENDING
  ACTIVE
  COMPLETED
  BLOCKED
}

model Milestone {
  id          String          @id @default(cuid())
  title       String
  description String?
  status      MilestoneStatus @default(PENDING)
  order       Int             @default(0)
  dueDate     DateTime?
  completedAt DateTime?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

// ----------------------------------------------------------------------------
// AI lead engine
// ----------------------------------------------------------------------------

enum LeadStatus {
  NEW
  QUALIFIED
  CONTACTED
  PROPOSAL_SENT
  WON
  LOST
}

enum LeadComplexity {
  LOW
  MEDIUM
  HIGH
  ENTERPRISE
}

model Lead {
  id           String         @id @default(cuid())
  name         String
  email        String
  company      String?
  phone        String?
  projectType  String?
  requirements String?
  budget       String?
  timeline     String?
  source       String         @default("assistant") // assistant | wizard | roi | contact

  // AI-derived fields
  score      Int            @default(0) // 0-100
  complexity LeadComplexity @default(MEDIUM)
  status     LeadStatus     @default(NEW)

  // optional link once a lead converts
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  conversation AIConversation?
  summary      AISummary?
  quotations   Quotation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([score])
}

enum ConversationChannel {
  ASSISTANT
  WIZARD
  RECEPTIONIST_DEMO
  ROI_CALCULATOR
}

model AIConversation {
  id      String              @id @default(cuid())
  channel ConversationChannel @default(ASSISTANT)

  leadId String? @unique
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  messages AIMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
}

model AIMessage {
  id             String      @id @default(cuid())
  conversationId String
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String
  createdAt      DateTime    @default(now())

  @@index([conversationId])
}

model AISummary {
  id                    String   @id @default(cuid())
  leadId                String   @unique
  lead                  Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  summary               String
  recommendedSolution   String
  projectScope          String[] // ordered scope items
  technicalRequirements String[]
  estimatedComplexity   LeadComplexity
  leadScore             Int
  createdAt             DateTime @default(now())
}

// ----------------------------------------------------------------------------
// Commercial objects
// ----------------------------------------------------------------------------

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model Quotation {
  id        String          @id @default(cuid())
  number    String          @unique
  title     String
  status    QuotationStatus @default(DRAFT)
  currency  String          @default("USD")
  amount    Decimal         @db.Decimal(12, 2)
  lineItems Json // [{ description, qty, unitPrice }]
  validUntil DateTime?
  notes     String?

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])
  leadId   String?
  lead     Lead?   @relation(fields: [leadId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

model Invoice {
  id        String        @id @default(cuid())
  number    String        @unique
  status    InvoiceStatus @default(DRAFT)
  currency  String        @default("USD")
  amount    Decimal       @db.Decimal(12, 2)
  lineItems Json
  issuedAt  DateTime?
  dueDate   DateTime?
  paidAt    DateTime?

  clientId String
  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([status])
}

enum MeetingStatus {
  REQUESTED
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Meeting {
  id          String        @id @default(cuid())
  title       String
  agenda      String?
  status      MeetingStatus @default(REQUESTED)
  scheduledAt DateTime?
  durationMin Int           @default(30)
  meetingUrl  String?

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  hostId   String?
  host     User?   @relation("MeetingHost", fields: [hostId], references: [id])
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

enum FileKind {
  DOCUMENT
  IMAGE
  CONTRACT
  DELIVERABLE
  OTHER
}

model File {
  id        String   @id @default(cuid())
  name      String
  url       String
  mimeType  String
  sizeBytes Int      @default(0)
  kind      FileKind @default(DOCUMENT)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  uploadedById String?
  uploadedBy   User?   @relation("FileUploader", fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([clientId])
}

enum NotificationType {
  LEAD
  PROJECT
  INVOICE
  MEETING
  MESSAGE
  SYSTEM
}

model Notification {
  id     String           @id @default(cuid())
  userId String
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   NotificationType @default(SYSTEM)
  title  String
  body   String?
  link   String?
  read   Boolean          @default(false)

  createdAt DateTime @default(now())

  @@index([userId, read])
}
