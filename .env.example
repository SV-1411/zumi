# =============================================================================
# ZUMI — environment variables (root reference)
# =============================================================================
# ZUMI runs as a single full-stack Next.js app (apps/web) on Vercel, backed by
# a Neon serverless Postgres database. Every value below is SERVER-ONLY and is
# never exposed to the browser.
#
# Local setup:   copy this file to apps/web/.env.local and fill in real values.
# Vercel setup:  add each variable under Project → Settings → Environment
#                Variables (Production + Preview).
# =============================================================================

# --- Database (Neon Postgres) ------------------------------------------------
# Use the POOLED endpoint (the `-pooler` host) on Vercel/serverless; the direct
# endpoint is fine locally. Run `npm run db:push` once to create the tables and
# `npm run db:seed` to create the seeded admin account.
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/db?sslmode=require"

# --- Auth (JWT) --------------------------------------------------------------
# Generate long random strings, e.g. `openssl rand -hex 32`. Use two DIFFERENT
# secrets for access and refresh tokens.
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
ACCESS_TOKEN_TTL=900          # access token lifetime (seconds) — default 15 min
REFRESH_TOKEN_TTL=2592000     # refresh token lifetime (seconds) — default 30 d

# --- AI consultant (OpenRouter) ---------------------------------------------
# Powers the conversational AI assistant. If unset, the app falls back to a
# scripted assistant flow (the site still works, just without live LLM replies).
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Email notifications (optional) -----------------------------------------
# Sends an email when a new inquiry/lead is captured. If unset, inquiries are
# only stored (and logged) — no email is sent.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
LEAD_NOTIFY_TO=you@youragency.com
