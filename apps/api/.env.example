# Server
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Database (shared with packages/db)
DATABASE_URL="postgresql://zumi:zumi@localhost:5432/zumi?schema=public"

# Auth
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
ACCESS_TOKEN_TTL=900            # 15 minutes (seconds)
REFRESH_TOKEN_TTL=2592000       # 30 days (seconds)

# Redis (optional — caching & rate limiting fall back gracefully if absent)
REDIS_URL=redis://localhost:6379
