# ZUMI web app — now a self-contained full-stack Next.js app (Vercel-native).
# All values below are server-only (never exposed to the browser).

# Postgres (Neon). Use the POOLED endpoint on Vercel/serverless, the direct
# endpoint locally. Run `npm run db:push` once to create tables.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Auth — generate long random strings (e.g. `openssl rand -hex 32`).
JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000

# OpenRouter LLM for the AI consultant (optional — scripted fallback if unset).
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxx
OPENROUTER_MODEL=openai/gpt-4o-mini

# Email notifications on new inquiries (optional — logs if unset).
RESEND_API_KEY=re_xxxxxxxx
LEAD_NOTIFY_TO=you@youragency.com
